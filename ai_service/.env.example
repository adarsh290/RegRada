# ── LLM Provider ────────────────────────────────────────────
# Options: "openai", "local" (Ollama), "fallback" (no LLM, hardcoded data)
MODEL_PROVIDER=fallback

# OpenAI settings (only needed if MODEL_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Local / Ollama settings (only needed if MODEL_PROVIDER=local)
LOCAL_MODEL=llama3.1
